# Vercel Blob results store. Unset locally -> the Benchmark Runner falls back to
# the committed files in public/results/. Both vars below must be set together
# (usingBlob() returns false unless both are present).
BLOB_READ_WRITE_TOKEN=
# Public base URL of the Blob store, used for O(1) reads of runs/suites.
# e.g. https://<id>.public.blob.vercel-storage.com
NEXT_PUBLIC_BLOB_BASE=
